{
  "rewrites": [
    {
      "source": "/site",
      "destination": "/site/index.html"
    },
    {
      "source": "/site/",
      "destination": "/site/index.html"
    },
    {
      "source": "/site/index",
      "destination": "/site/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "same-origin"
        }
      ]
    }
  ]
}